# Terraform
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.json
*.tfplan
!*.tfvars.example
.terraform.lock.hcl
crash.log
crash.*.log

# Ansible
.ansible/
*.retry
ansible/inventory.yml
ansible/.vault_pass
ansible/group_vars/**/vault.yml

# Kubeconfig / 비밀정보
kubeconfig
kubeconfig.*
*.kubeconfig
.kube-local/
**/secrets/
*.pem
# 5명 분배용 kubeconfig (kubelogin OIDC, public CA only — sensitive 없음) 는 git commit 허용.
!infra/kubernetes/kubeconfig/
!infra/kubernetes/kubeconfig/**
*.key
!**/cloud-init/*.key
*.pfx
*.p12

# Vault bootstrap secrets (root token + unseal keys)
vault-bootstrap*.json

# OS / 에디터
.DS_Store
.vscode/
.idea/

# Python
__pycache__/
*.pyc
.venv/
venv/
.pre-commit-cache*/
.ansible-home/
.pc-cache*/
.pytest_cache/
.ruff_cache/

# Node
node_modules/
.next/
dist/
build/

# 로컬 임시
/tmp/
scratch/
.tmp/
.kubelogin-cache/

