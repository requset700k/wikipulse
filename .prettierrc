{
  "printWidth": 100,
  "tabWidth": 2,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "arrowParens": "always",
  "bracketSpacing": true,
  "endOfLine": "lf",
  "overrides": [
    {
      "files": ["*.yml", "*.yaml"],
      "options": { "singleQuote": false, "tabWidth": 2 }
    },
    {
      "files": ["*.md", "*.mdx"],
      "options": { "proseWrap": "preserve" }
    }
  ]
}
